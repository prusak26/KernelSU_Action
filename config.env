CONFIG_ENV=config.env

# Мы НЕ компилируем, поэтому эти строки оставляем пустыми или не трогаем
KERNEL_SOURCE=
KERNEL_SOURCE_BRANCH=
KERNEL_CONFIG=
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64

# Настройки ядра для твоего A50
CLANG_VERSION=r383902
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# КРИТИЧЕСКИЕ НАСТРОЙКИ ДЛЯ KSU
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=false

# Сборка образа (ТВОЙ СЛУЧАЙ)
BUILD_BOOT_IMG=true
# Вставь сюда свою прямую ссылку на boot.img от crDroid
SOURCE_BOOT_IMAGE=https://drive.google.com/file/d/1SEOc1TNmIt9LDrkjYdFm0MeMjruJhBbl/view?usp=sharing
