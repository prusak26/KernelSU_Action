CONFIG_ENV=config.env

# Оставляем пустым, чтобы не скачивать гигабайты исходников
KERNEL_SOURCE=
KERNEL_SOURCE_BRANCH=
KERNEL_CONFIG=
KERNEL_IMAGE_NAME=boot.img

# Параметры для твоего Samsung A50
ARCH=arm64
# Используем минимальную версию Clang, может она проскочит
CLANG_VERSION=r383902

# KernelSU - СТАВИМ СТРОГО 0.9.5
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# САМЫЙ ВАЖНЫЙ БЛОК: ПАТЧИНГ ГОТОВОГО ФАЙЛА
BUILD_BOOT_IMG=true
# Твоя ссылка на Google Drive (через uc?export=download&id=...)
SOURCE_BOOT_IMAGE=https://pixeldrain.com/api/file/SqZYwFty
